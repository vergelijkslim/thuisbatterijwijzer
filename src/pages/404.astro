---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina niet gevonden" description="De pagina die je zoekt bestaat niet of is verplaatst." noindex={true}>
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p class="subtitle">Pagina niet gevonden</p>
      <p>De pagina die je zoekt bestaat niet of is verplaatst.</p>
      <div class="actions">
        <a href="/" class="btn btn-primary">Terug naar home</a>
        <a href="/artikelen/" class="btn btn-outline-dark">Bekijk artikelen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding: 6rem 0;
    text-align: center;
  }
  .not-found h1 {
    font-size: 6rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    line-height: 1;
  }
  .subtitle {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .not-found > .container > p {
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-outline-dark {
    background: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .btn-outline-dark:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-light);
  }
</style>
