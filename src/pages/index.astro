---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ThuisbatterijWijzer.nl',
  url: Astro.site?.href,
  description: 'Onafhankelijke gids voor thuisbatterijen en energieopslag in Nederland',
  inLanguage: 'nl',
};

const allArticles = (await getCollection('thuisbatterij'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured).slice(0, 3);
const latest = allArticles.slice(0, 6);

const gidsen = allArticles.filter((a) => a.data.type === 'gids');
const vergelijkingen = allArticles.filter((a) => a.data.type === 'vergelijking');

const typeLabels: Record<string, string> = {
  vergelijking: 'Vergelijking',
  review: 'Review',
  gids: 'Gids',
};

const sections = [
  {
    title: 'Gidsen & Advies',
    description: 'Uitgebreide handleidingen over kosten, subsidies en installatie van thuisbatterijen.',
    href: '/gidsen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    count: gidsen.length,
  },
  {
    title: 'Vergelijkingen',
    description: 'Vergelijk merken, capaciteiten en installateurs naast elkaar.',
    href: '/vergelijkingen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    count: vergelijkingen.length,
  },
  {
    title: 'Zonnepanelen combineren',
    description: 'Leer hoe je thuisbatterijen combineert met zonnepanelen voor maximaal rendement.',
    href: 'https://zonnewijzer.nl/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    count: null,
  },
];
---

<BaseLayout
  title="ThuisbatterijWijzer.nl"
  description="Onafhankelijk advies over thuisbatterijen, energieopslag, prijzen en subsidies. Vergelijk aanbieders en bespaar op je energierekening."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-content">
      <span class="hero-badge">Onafhankelijk & Eerlijk</span>
      <h1>Jouw gids voor<br />thuisbatterijen</h1>
      <p class="hero-sub">
        Onafhankelijk advies over thuisbatterijen en energieopslag.
        Vergelijk aanbieders en vind de beste oplossing voor jouw situatie.
      </p>
      <div class="hero-cta">
        <a href="/offerte/" class="btn btn-cta">Gratis offertes aanvragen</a>
        <a href="/vergelijkingen/" class="btn btn-outline">Vergelijk batterijen</a>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>100% onafhankelijk</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
          <span>Specialist in energieopslag</span>
        </div>
        <div class="trust-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Gratis offertes vergelijken</span>
        </div>
      </div>
    </div>
  </section>

  <section class="sections" id="onderwerpen">
    <div class="container">
      <div class="section-header">
        <h2>Onze onderwerpen</h2>
        <p>Alles wat je moet weten over thuisbatterijen, van kosten tot installatie.</p>
      </div>
      <div class="section-grid">
        {sections.map((section) => (
          <a href={section.href} class="section-card">
            <div class="section-icon">
              <Fragment set:html={section.icon} />
            </div>
            <h3>{section.title}</h3>
            <p>{section.description}</p>
            {section.count !== null && (
              <span class="section-meta">{section.count} artikelen &rarr;</span>
            )}
            {section.count === null && (
              <span class="section-meta">Bezoek ZonneWijzer.nl &rarr;</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <div class="container">
        <div class="section-header">
          <h2>Uitgelichte artikelen</h2>
          <p>Onze meest gelezen gidsen en vergelijkingen.</p>
        </div>
        <div class="featured-grid">
          {featured.map((article) => (
            <a href={`/thuisbatterij/${article.id}/`} class="featured-card">
              <div class="featured-card-top">
                <span class="badge badge-cyan">{typeLabels[article.data.type] || article.data.type}</span>
              </div>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <div class="featured-card-meta">
                <span>{article.data.author}</span>
                <span>&middot;</span>
                <span>{article.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {latest.length > 0 && (
    <section class="latest">
      <div class="container">
        <div class="section-header">
          <h2>Laatste artikelen</h2>
          <p>Recent gepubliceerd en bijgewerkt.</p>
        </div>
        <div class="latest-grid">
          {latest.map((article) => (
            <a href={`/thuisbatterij/${article.id}/`} class="latest-card">
              <span class="badge badge-primary">{typeLabels[article.data.type] || article.data.type}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
            </a>
          ))}
        </div>
        <div class="view-all">
          <a href="/artikelen/" class="btn btn-primary">Bekijk alle artikelen</a>
        </div>
      </div>
    </section>
  )}

  <section class="offerte-cta">
    <div class="container">
      <div class="offerte-cta-card">
        <h2>Klaar om energie op te slaan?</h2>
        <p>Ontvang gratis en vrijblijvend offertes van gecertificeerde installateurs bij jou in de buurt. Vergelijk en bespaar op je thuisbatterij.</p>
        <div class="offerte-cta-buttons">
          <a href="/offerte/" class="btn btn-cta">Vraag gratis offertes aan</a>
        </div>
        <p class="offerte-note"><small>100% gratis &middot; Geen verplichtingen &middot; Binnen 48 uur reactie</small></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #164e63 0%, #155e75 40%, #0891b2 70%, #06b6d4 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(103,232,249,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }
  .hero h1 {
    color: #fff;
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-size: 1.125rem;
    opacity: 0.85;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-cta .btn {
    font-size: 1rem;
    padding: 0.875rem 2rem;
  }
  .btn-outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: var(--radius-lg);
  }
  .btn-outline:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.7);
    color: #fff;
  }
  @media (min-width: 768px) {
    .hero { padding: 6rem 0 7rem; }
    .hero h1 { font-size: 3.5rem; }
    .hero-sub { font-size: 1.25rem; }
  }

  .trust-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
  }
  .trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .trust-items { gap: 3rem; }
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-header p {
    color: var(--color-text-light);
    font-size: 1.0625rem;
    margin-top: 0.5rem;
  }

  .sections {
    padding: 4rem 0;
  }
  .section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .section-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .section-card {
    display: block;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-base);
  }
  .section-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: var(--color-primary-light);
  }
  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    margin-bottom: 1.25rem;
    background: var(--color-primary-light);
    color: var(--color-primary);
  }
  .section-card h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .section-card p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .section-meta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .featured {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .featured-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    transition: all var(--transition-base);
  }
  .featured-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .featured-card-top {
    margin-bottom: 0.75rem;
  }
  .featured-card h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .featured-card p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }
  .featured-card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-light);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .latest {
    padding: 4rem 0;
  }
  .latest-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .latest-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .latest-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    transition: all var(--transition-base);
  }
  .latest-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    border-color: var(--color-primary-light);
  }
  .latest-card h3 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .latest-card p {
    color: var(--color-text-light);
    font-size: 0.8125rem;
    line-height: 1.5;
  }
  .view-all {
    text-align: center;
    margin-top: 2rem;
  }

  .offerte-cta {
    padding: 4rem 0;
    background: var(--color-bg-alt);
  }
  .offerte-cta-card {
    background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%);
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-xl);
    padding: 3rem 2rem;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .offerte-cta-card h2 {
    margin-bottom: 0.75rem;
  }
  .offerte-cta-card > p {
    color: var(--color-text-light);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .offerte-cta-buttons {
    margin-bottom: 1rem;
  }
  .offerte-note small {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }
</style>
