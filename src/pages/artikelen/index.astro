---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('thuisbatterij'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const typeLabels: Record<string, string> = {
  vergelijking: 'Vergelijking',
  review: 'Review',
  gids: 'Gids',
};
---

<BaseLayout title="Alle artikelen" description="Alle artikelen over thuisbatterijen, energieopslag en kosten op ThuisbatterijWijzer.nl.">
  <section class="articles-page">
    <div class="container">
      <h1>Alle artikelen</h1>
      <p class="page-intro">Al onze gidsen, vergelijkingen en reviews over thuisbatterijen en energieopslag.</p>

      {allArticles.length === 0 && (
        <p class="empty">Er zijn nog geen artikelen gepubliceerd. Kom binnenkort terug!</p>
      )}

      <div class="articles-grid">
        {allArticles.map((article) => (
          <a href={`/thuisbatterij/${article.id}/`} class="article-card">
            <span class="badge badge-primary">{typeLabels[article.data.type] || article.data.type}</span>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
            <div class="article-meta">
              <span>{article.data.author}</span>
              <span>&middot;</span>
              <span>{article.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .articles-page { padding: 3rem 0; }
  .articles-page h1 { margin-bottom: 0.5rem; }
  .page-intro { color: var(--color-text-light); margin-bottom: 2.5rem; }
  .empty { color: var(--color-text-muted); font-style: italic; }
  .articles-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 640px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .articles-grid { grid-template-columns: repeat(3, 1fr); } }
  .article-card {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 1.5rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); color: var(--color-text);
    transition: all var(--transition-base);
  }
  .article-card:hover { text-decoration: none; box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .article-card h2 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 600; line-height: 1.4; }
  .article-card p { color: var(--color-text-light); font-size: 0.875rem; line-height: 1.6; flex: 1; }
  .article-meta {
    display: flex; align-items: center; gap: 0.375rem;
    padding-top: 0.75rem; border-top: 1px solid var(--color-border-light);
    font-size: 0.8125rem; color: var(--color-text-muted);
  }
</style>
